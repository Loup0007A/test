<%- include('../partials/header') %>

<main class="game-page">

  <!-- ── Header ── -->
  <div class="gp-header">
    <a href="/games" class="gp-back">← Retour</a>
    <div class="gp-title">
      <span class="gp-icon"><%= game.icon %></span>
      <h1><%= game.name %></h1>
    </div>
    <div class="gp-badges">
      <span class="gp-badge"><%= game.category %></span>
      <span class="gp-diff gp-diff-<%= game.difficulty.toLowerCase() %>"><%= game.difficulty %></span>
      <% if (user) { %><span class="gp-user"><%= user.avatar %> <%= user.username %></span><% } %>
    </div>
  </div>

  <!-- ── Layout ── -->
  <div class="gp-layout">

    <!-- Arena -->
    <div class="gp-main">

      <!-- Countdown overlay (shown before game starts) -->
      <div class="gp-countdown" id="gpCountdown">
        <div class="gp-countdown-icon"><%= game.icon %></div>
        <div class="gp-countdown-name"><%= game.name %></div>
        <div class="gp-countdown-desc"><%= game.desc %></div>
        <div class="gp-countdown-num" id="gpCountNum">3</div>
        <div class="gp-countdown-label">Démarrage dans…</div>
        <% if (!user) { %>
          <p class="gp-login-hint"><a href="/login">Connecte-toi</a> pour sauvegarder ton score</p>
        <% } %>
      </div>

      <!-- Game canvas area -->
      <div class="gp-arena game-panel-hidden" id="gameContainer"></div>

      <!-- Result overlay -->
      <div class="gp-result game-panel-hidden" id="gameResult">
        <div class="gp-result-icon" id="resultIcon"></div>
        <h2 class="gp-result-title" id="resultTitle"></h2>
        <p class="gp-result-msg" id="resultMsg"></p>
        <div class="gp-result-score">Score&nbsp;<span id="resultScore">0</span></div>
      </div>

    </div>

    <!-- Sidebar -->
    <aside class="gp-sidebar">
      <div class="gp-card">
        <div class="gp-card-label">Adversaire</div>
        <div class="gp-robot">
          <div class="gp-robot-face">🤖</div>
          <div class="gp-robot-name">BOT-<%= game.id.toUpperCase().slice(0,4) %></div>
          <div class="gp-robot-lvl">Niv. <%= game.difficulty === 'Facile' ? '1' : game.difficulty === 'Moyen' ? '3' : '5' %></div>
        </div>
      </div>
      <% if (leaderboard && leaderboard.length > 0) { %>
      <div class="gp-card">
        <div class="gp-card-label">Top scores</div>
        <div class="gp-lb">
          <% leaderboard.slice(0,5).forEach((e, i) => { %>
          <div class="gp-lb-row">
            <span><%= i===0?'🥇':i===1?'🥈':i===2?'🥉':'#'+(i+1) %></span>
            <span class="gp-lb-name"><%= e.username %></span>
            <span class="gp-lb-score"><%= e.score %></span>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </aside>
  </div>

  <!-- Reload button OUTSIDE the arena -->
  <div class="gp-reload-bar">
    <button class="gp-reload-btn" onclick="location.reload()">↺ Rejouer</button>
    <a href="/games" class="gp-reload-link">← Tous les jeux</a>
  </div>

</main>

<script>
var GAME_ID   = '<%= game.id %>';
var GAME_NAME = '<%= game.name %>';
var IS_LOGGED = <%= user ? 'true' : 'false' %>;
</script>
<script src="/js/games/engine.js"></script>
<script src="/js/games/stubs.js"></script>
<script src="/js/games/<%= game.id %>.js" onerror=""></script>
<script>
// ── Auto-countdown then start ──
(function() {
  var n = 3;
  var el = document.getElementById('gpCountNum');
  function tick() {
    if (n <= 0) {
      // Hide countdown, start game
      var cd = document.getElementById('gpCountdown');
      if (cd) cd.classList.add('game-panel-hidden');
      if (typeof startGame === 'function') startGame();
      return;
    }
    if (el) {
      el.textContent = n;
      el.classList.remove('gp-pop');
      void el.offsetWidth; // reflow to restart animation
      el.classList.add('gp-pop');
    }
    n--;
    setTimeout(tick, 1000);
  }
  // Small delay so all scripts have loaded
  setTimeout(tick, 300);
})();
</script>

<%- include('../partials/footer') %>
