server {
    listen 80;
    server_name roboarena.io www.roboarena.io;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name roboarena.io www.roboarena.io;

    ssl_certificate /etc/letsencrypt/live/roboarena.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/roboarena.io/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/javascript application/json;
    gzip_min_length 1024;

    # Static files cache
    location /css/ { expires 1d; add_header Cache-Control "public"; proxy_pass http://localhost:3000; }
    location /js/  { expires 1d; add_header Cache-Control "public"; proxy_pass http://localhost:3000; }

    # Main proxy
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
